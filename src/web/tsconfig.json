{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "outDir": "./dist",
    "rootDir": "..",
    "noEmit": false,
    "module": "ESNext",
    "target": "ES2019",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "./**/*.ts",
    "../core/cpu1.ts",
    "../core/cpu-interface.ts",
    "../core/constants.ts",
    "../runners/basic-traps.ts",
    "../utils/disasm.ts"
  ],
  "exclude": [
    "./dist",
    "../../node_modules"
  ]
}
